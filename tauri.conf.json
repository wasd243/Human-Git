{
  "productName": "Human-Git",
  "version": "0.1.0",
  "identifier": "com.humangit.dev",
  "build": {
    "beforeDevCommand": "npm run dev --prefix src/app/desktop",
    "beforeBuildCommand": "npm run build --prefix src/app/desktop",
    "devUrl": "http://localhost:5173",
    "frontendDist": "src/app/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "label": "main",
        "resizable": true,
        "title": "Human-Git Dashboard",
        "transparent": true,
        "width": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}